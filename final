      +'<div class="item-body">'
        +'<div class="upload-zone" id="uz'+i+'" ondragover="dov(event,'+i+')" ondragleave="dlv(event,'+i+')" ondrop="drp(event,'+i+')">'
          +'<input type="file" id="fi'+i+'" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.heic,image/heic" onchange="hFile('+i+',this)">'
          +'<div class="upload-icon-wrap">'+svg('upload',20)+'</div>'
          +'<div class="upload-title">اسحب الملف هنا أو اضغط للاختيار</div>'
          +'<div class="upload-hint">الحد الأقصى '+MAX_MB+'MB</div>'
          +'<div class="file-chips">'+ALLOWED.map(function(e){return '<span class="file-chip">'+e.toUpperCase()+'</span>';}).join('')+'</div>'
        +'</div>'
        +'<div class="file-prev" id="fp'+i+'">'
          +'<div class="file-prev-icon">'+svg('doc',17)+'</div>'
          +'<div class="file-prev-info"><div class="file-prev-name" id="fn'+i+'"></div><div class="file-prev-size" id="fs'+i+'"></div></div>'
          +'<div class="file-rem" onclick="rmFile('+i+')">'+svg('x',12)+'</div>'
        +'</div>'
        +'<div class="or-sep">أو</div>'
        +'<label class="note-lbl">سبب عدم التوفر <span class="note-req">(إجباري إذا لم يُرفع ملف)</span></label>'
        +'<textarea class="note-ta" id="nt'+i+'" placeholder="مثال: المستند قيد التجديد..." oninput="hNote('+i+',this.value)" rows="3"></textarea>'
        +'<button class="confirm-btn" onclick="markDone('+i+',\''+nm+'\')">'
          +svg('check',15)+' تأكيد'
        +'</button>'
      +'</div>';
    c.appendChild(el);
  });
}

function togCard(i){
  var card=ge('dc'+i);
  if(card.classList.contains('completed')){showToast('تم تأكيد هذا الملف مسبقاً','tw');return;}
  var was=card.classList.contains('expanded');
  document.querySelectorAll('.doc-item').forEach(function(x){x.classList.remove('expanded');});
  if(!was)card.classList.add('expanded');
}

/* ─ FILE HANDLING ─ */
function dov(e,i){e.preventDefault();ge('uz'+i).classList.add('drag');}
function dlv(e,i){ge('uz'+i).classList.remove('drag');}
function drp(e,i){e.preventDefault();ge('uz'+i).classList.remove('drag');var f=e.dataTransfer.files[0];if(f)procFile(i,f);}
function hFile(i,inp){var f=inp.files[0];if(f)procFile(i,f);}
function procFile(i,f){
  var ext=f.name.split('.').pop().toLowerCase();
  if(ALLOWED.indexOf(ext)<0){showToast('نوع الملف غير مدعوم','te');return;}
  if(f.size>MAX_MB*1024*1024){showToast('الملف أكبر من '+MAX_MB+'MB','te');return;}
  DS[DR.missing[i].name].file=f;
  ge('fn'+i).textContent=f.name;
  ge('fs'+i).textContent=(f.size/1024).toFixed(0)+' KB';
  ge('uz'+i).style.display='none';
  ge('fp'+i).classList.add('on');
}
function rmFile(i){
  DS[DR.missing[i].name].file=null;
  ge('fi'+i).value='';
  ge('fp'+i).classList.remove('on');
  ge('uz'+i).style.display='';
}
function hNote(i,v){DS[DR.missing[i].name].note=v;ge('nt'+i).classList.remove('ef');}

/* ─ MARK DONE ─ */
function markDone(i,name){
  var st=DS[name];
  if(!st.file&&!st.note.trim()){
    ge('nt'+i).classList.add('ef');ge('nt'+i).focus();
    showToast('يرجى رفع الملف أو كتابة سبب','te');return;
  }
  st.done=true;st.type=st.file?'file':'note';
  var card=ge('dc'+i);
  card.classList.add('completed');card.classList.remove('expanded');
  var b=ge('bdg'+i);
  b.className='item-badge '+(st.file?'b-done':'b-note');
  b.textContent=st.file?'تم الرفع':'بعذر';
  updProg();showToast('تم تسجيل الملف','ts');
  var all=DR.missing;
  for(var j=i+1;j<all.length;j++){
    if(!DS[all[j].name].done){
      (function(jj){setTimeout(function(){
        ge('dc'+jj).classList.add('expanded');
        ge('dc'+jj).scrollIntoView({behavior:'smooth',block:'center'});
      },320);})(j);
      break;
    }
  }
}

/* ─ PROGRESS ─ */
function updProg(){
  var tot=DR.missing.length;
  var done=0;Object.keys(DS).forEach(function(k){if(DS[k].done)done++;});
  var pct=tot?Math.round(done/tot*100):0;
  ge('hp-dn').textContent=done;ge('hp-tot').textContent=tot;
  ge('hp-pct').textContent=pct+'%';ge('hp-fl').style.width=pct+'%';
  ge('st-dn').textContent=done;
  ge('hdr-pf').style.width=pct+'%';
  ge('hdr-pt').textContent=done+'/'+tot;
}

/* ─ SUBMIT ─ */
function doSubmit(){
  var ud=[];Object.keys(DS).forEach(function(k){if(!DS[k].done)ud.push(k);});
  if(ud.length){showToast('لم تكمل '+ud.length+' ملف','te');return;}
  var btn=ge('sb');btn.disabled=true;
  ge('sb-t').style.display='none';ge('sb-sp').style.display='';
  var p=new URLSearchParams();
  p.append('action','submit');p.append('doctorId',DR.id);p.append('doctorName',DR.name);
  p.append('dept',DR.dept||'');p.append('spec',DR.spec||'');p.append('timestamp',new Date().toISOString());
  var rows=[];var fc=0,nc=0;
  var keys=Object.keys(DS);var idx=0;
  function next(){
    if(idx>=keys.length){
      p.append('data',JSON.stringify(rows));
      fetch(GAS,{method:'POST',body:p,headers:{'Content-Type':'application/x-www-form-urlencoded'}})
      .then(function(r){return r.json();})
      .then(function(j){
        if(j.status==='ok')showSuc(j.submissionId||(DR.id+'-'+Date.now().toString(36).toUpperCase()),fc,nc);
        else throw new Error(j.message);
      })
      .catch(function(e){
        btn.disabled=false;ge('sb-t').style.display='';ge('sb-sp').style.display='none';
        showToast('فشل الإرسال: '+e.message,'te');
      });
      return;
    }
    var nm=keys[idx];var st=DS[nm];idx++;
    rows.push({doc:nm,hasFile:!!st.file,note:st.note});
    if(st.file){
      fc++;var rd=new FileReader();
      rd.onload=function(){p.append('file_b64_'+encodeURIComponent(nm),st.file.name+'||'+st.file.type+'||'+rd.result.split(',')[1]);next();};
      rd.readAsDataURL(st.file);
    }else{if(st.note)nc++;next();}
  }
  next();
}

function showSuc(sid,fc,nc){
  var now=new Date();
  ge('sv-id').textContent=sid;
  ge('sv-dt').textContent=now.toLocaleDateString('ar-SA',{year:'numeric',month:'long',day:'numeric',hour:'2-digit',minute:'2-digit'});
  ge('sv-fl').textContent=fc+' ملف';
  ge('suc-sub').textContent='شكراً لك، '+DR.name+'. تم استلام الملفات وسيتم مراجعتها من قبل الفريق المختص.';
  showScr('success');
}

/* ─ ADMIN ─ */
function loadAdm(data){
  if(!data)return;ADM=data.doctors||[];
  ge('ki-t').textContent=data.total||0;ge('ki-c').textContent=data.complete||0;
  ge('ki-p').textContent=data.partial||0;ge('ki-n').textContent=data.notStarted||0;
  ge('ki-f').textContent=data.totalFiles||0;ge('ki-no').textContent=data.totalNotes||0;
  var av=data.avgCompletion||0;ge('avg-p').textContent=av+'%';ge('avg-f').style.width=av+'%';
  renderAdmTbl(ADM);
  ge('a-srch').addEventListener('input',function(e){
    var q=e.target.value.toLowerCase();
    renderAdmTbl(ADM.filter(function(d){return d.name.toLowerCase().indexOf(q)>=0||d.id.indexOf(q)>=0;}));
  });
}
function renderAdmTbl(docs){
  var tb=ge('a-tbl');tb.innerHTML='';
  docs.forEach(function(d){
    var p=d.completionPct||0;
    var cls=p>=100?'s-done':p>0?'s-part':'s-none';
    var lbl=p>=100?'مكتمل':p>0?'جزئي':'لم يبدأ';
    var tr=document.createElement('tr');
    tr.innerHTML=
      '<td style="font-weight:700;color:var(--navy)">'+d.id+'</td>'
      +'<td style="text-align:right;font-weight:500">'+d.name+'</td>'
      +'<td>'+(d.mobile||'—')+'</td>'
      +'<td style="text-align:right;font-size:11px">'+(d.dept||'—')+'</td>'
      +'<td>'+( d.required||0)+'</td>'
      +'<td style="color:#1a8c37;font-weight:700">'+(d.uploaded||0)+'</td>'
      +'<td style="color:#b06000;font-weight:700">'+(d.notes||0)+'</td>'
      +'<td>'
        +'<div style="background:var(--bg);border-radius:3px;height:5px;width:72px;margin:0 auto;overflow:hidden">'
          +'<div style="height:100%;width:'+p+'%;background:linear-gradient(90deg,var(--teal),var(--blue2));border-radius:3px"></div>'
        +'</div>'
        +'<div style="font-size:10px;margin-top:3px;font-weight:600;color:var(--text2)">'+p+'%</div>'
      +'</td>'
      +'<td><span class="s-pill '+cls+'">'+lbl+'</span></td>'
      +'<td style="font-size:10px;color:var(--text3)">'+(d.lastUpdated||'—')+'</td>';
    tr.onclick=function(){openDet(d);};
    tb.appendChild(tr);
  });
}
function openDet(d){
  ge('det-ttl').textContent=d.name+' — '+d.id;
  var h='<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;font-size:12px">'
    +'<div><strong>القسم:</strong> '+(d.dept||'—')+'</div>'
    +'<div><strong>الجوال:</strong> '+(d.mobile||'—')+'</div>'
    +'<div><strong>التخصص:</strong> '+(d.spec||'—')+'</div>'
    +'<div><strong>الاكتمال:</strong> '+(d.completionPct||0)+'%</div>'
  +'</div>'
  +'<div style="font-weight:700;font-size:13px;color:var(--navy);margin-bottom:10px">الملفات المطلوبة</div>';
  (d.documents||[]).forEach(function(doc){
    var cc=doc.fileUrl?'#1a8c37':doc.note?'#b06000':'var(--red)';
    var st=doc.fileUrl?'مرفوع':doc.note?'بعذر':'ناقص';
    h+='<div class="det-doc-row">'
      +'<div style="width:32px;height:32px;border-radius:8px;background:'+(doc.fileUrl?'rgba(52,199,89,.1)':doc.note?'rgba(255,159,10,.1)':'rgba(255,59,48,.07)')
        +';display:flex;align-items:center;justify-content:center;flex-shrink:0;color:'+cc+'">'
        +svg(doc.is_qual?'academic':'doc',16)
      +'</div>'
      +'<div style="flex:1">'
        +'<div style="font-size:13px;font-weight:600;color:var(--text)">'+doc.name+'</div>'
        +'<div style="font-size:11px;color:'+cc+';font-weight:600;margin-top:2px">'+st
          +(doc.fileUrl?' · <a href="'+doc.fileUrl+'" target="_blank" style="color:var(--blue)">فتح الملف</a>':'')
        +'</div>'
        +(doc.note?'<div style="font-size:11px;background:var(--bg);border-radius:6px;padding:4px 8px;margin-top:4px;color:var(--text3);line-height:1.6">'+doc.note+'</div>':'')
      +'</div>'
    +'</div>';
  });
  ge('det-body').innerHTML=h;
  ge('det-mod').classList.add('on');
}
function closeDet(){ge('det-mod').classList.remove('on');}
function expCSV(){
  var h=['Employee ID','Name','Mobile','Department','Document','Status','File URL','Note','Date','Completion%','Final'];
  var rows=[h];
  ADM.forEach(function(d){(d.documents||[]).forEach(function(doc){
    rows.push([d.id,d.name,d.mobile||'',d.dept||'',doc.name,
      doc.fileUrl?'Uploaded':doc.note?'Note':'Missing',
      doc.fileUrl||'',doc.note||'',doc.uploadDate||'',
      (d.completionPct||0)+'%',
      d.completionPct>=100?'Complete':d.completionPct>0?'Partial':'Not Started']);
  });});
  var csv=rows.map(function(r){return r.map(function(c){return '"'+String(c).replace(/"/g,'""')+'"';}).join(',');}).join('\n');
  var a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'}));
  a.download='Files_'+new Date().toISOString().slice(0,10)+'.csv';a.click();
}

/* ─ LOGOUT ─ */
function doLogout(){
  DR=null;DS={};IS_ADM=false;
  ge('f-id').value='';ge('f-mob').value='';
  ge('lg-err').classList.remove('on');
  showScr('login');
}

/* ─ HELPERS ─ */
function setLoad(bid,sid,tid,on){
  ge(bid).disabled=on;
  ge(sid).style.display=on?'':'none';
  var t=ge(tid);if(t)t.style.display=on?'none':'';
}
var _tt;
function showToast(msg,type){
  clearTimeout(_tt);var t=ge('tst');
  t.textContent=msg;t.className='toast '+(type||'');
  void t.offsetWidth;t.classList.add('on');
  _tt=setTimeout(function(){t.className='toast '+(type||'');},3200);
}
/* Ripple */
document.addEventListener('click',function(e){
  var b=e.target.closest('.login-btn,.wl-btn,.submit-btn,.close-btn,.confirm-btn');
  if(!b)return;
  var r=document.createElement('span');r.className='rpl';
  var rc=b.getBoundingClientRect();var sz=Math.max(rc.width,rc.height)*2;
  r.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+(e.clientX-rc.left-sz/2)+'px;top:'+(e.clientY-rc.top-sz/2)+'px';
  b.appendChild(r);setTimeout(function(){r.remove();},600);
});
/* Enter keys */
document.addEventListener('DOMContentLoaded',function(){
  ge('f-id').addEventListener('keydown',function(e){if(e.key==='Enter')doLogin();});
  ge('f-mob').addEventListener('keydown',function(e){if(e.key==='Enter')doLogin();});
  ge('adm-inp').addEventListener('keydown',function(e){if(e.key==='Enter')doAdmLogin();});
});

