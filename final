  ge('wl-nm').textContent='مرحباً، '+DR.name;
  ge('wl-mod').classList.add('on');
}
function closeWlMod(){
  ge('wl-mod').classList.remove('on');
  setTimeout(function(){initPortal();showScr('portal');},280);
}

/* ─ ADMIN MODAL ─ */
function openAdmMod(){ge('adm-mod').classList.add('on');setTimeout(function(){ge('adm-inp').focus();},180);}
function closeAdmMod(){ge('adm-mod').classList.remove('on');}
function doAdmLogin(){
  var code=ge('adm-inp').value.trim();if(!code)return;
  ge('adm-err').classList.remove('on');
  setLoad('adm-btn','adm-sp','adm-bt',true);
  fetch(GAS,{method:'POST',body:new URLSearchParams({action:'verifyAdmin',code:code}),headers:{'Content-Type':'application/x-www-form-urlencoded'}})
  .then(function(r){return r.json();})
  .then(function(j){
    if(j.status==='ok'&&j.authorized){closeAdmMod();IS_ADM=true;loadAdm(j.data);showScr('admin');}
    else ge('adm-err').classList.add('on');
  })
  .catch(function(){ge('adm-err').classList.add('on');})
  .finally(function(){setLoad('adm-btn','adm-sp','adm-bt',false);});
}

/* ─ PORTAL INIT ─ */
function initPortal(){
  var d=DR;
  ge('hdr-nm').textContent=d.name;
  ge('h-nm').textContent=d.name;
  ge('h-dept').textContent=[d.dept,d.spec].filter(Boolean).join(' · ');
  DS={};
  d.missing.forEach(function(m){DS[m.name]={file:null,note:'',done:false,type:null};});
  buildCards();updProg();
}

