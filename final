  document.querySelectorAll('.scr').forEach(function(s){s.classList.remove('on');});
  ge('scr-'+id).classList.add('on');
  window.scrollTo({top:0,behavior:'smooth'});
}

/* ─ TAB SWITCH ─ */
function swTab(t){
  ge('t-id').classList.toggle('on',t==='id');
  ge('t-mob').classList.toggle('on',t==='mob');
  ge('div-id').style.display=(t==='id')?'':'none';
  ge('div-mob').style.display=(t==='mob')?'':'none';
  ge('lg-err').classList.remove('on');
  ge('f-id').classList.remove('err');
  ge('f-mob').classList.remove('err');
  setTimeout(function(){ge(t==='id'?'f-id':'f-mob').focus();},40);
}

/* ─ LOGIN ─ */
function doLogin(){
  ge('lg-err').classList.remove('on');
  var isId=ge('t-id').classList.contains('on');
  var val=(isId?ge('f-id'):ge('f-mob')).value.trim();
  if(!val){
    ge('lg-em').textContent='يرجى إدخال '+(isId?'الرقم الوظيفي':'رقم الجوال');
    ge('lg-err').classList.add('on');
    setTimeout(function(){ge('lg-err').classList.remove('on');},4000);
    return;
  }
  setLoad('lg-btn','lg-sp','lg-bt',true);
  setTimeout(function(){
    var found=null;
    var keys=Object.keys(DB);
    for(var i=0;i<keys.length;i++){
      var id=keys[i];var d=DB[id];
      var m=d.mobile||'';
      var mn=m.charAt(0)==='0'?m:'0'+m;
      var vn=val.charAt(0)==='0'?val:'0'+val;
      if(isId?(id===val):(mn===vn||m===val)){found=Object.assign({id:id},d);break;}
    }
    setLoad('lg-btn','lg-sp','lg-bt',false);
    if(!found){
      ge('lg-em').textContent='لم يتم العثور على بياناتك. تحقق من الرقم وحاول مجدداً.';
      ge('lg-err').classList.add('on');
      (isId?ge('f-id'):ge('f-mob')).classList.add('err');
      setTimeout(function(){ge('lg-err').classList.remove('on');},5000);
      return;
    }
    DR=found;openWlMod();
  },700);
}

